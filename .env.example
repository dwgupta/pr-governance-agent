# LLM
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_BASE=

# LangSmith — tracing + token usage at https://smith.langchain.com
# Create API key: Settings → API Keys (starts with lsv2_pt_...)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=pr-governance-agent
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# GitHub
GITHUB_TOKEN=
SANDBOX_REPO=dwgupta/migration-sandbox-capstone
ALLOW_WRITE_ACTIONS=false
USE_PR_FIXTURE=false
# Optional: python scripts/github_mcp_bridge.py  (reads stdin JSON, prints PR payload)
GITHUB_MCP_COMMAND=

# Persist LangGraph state under data/checkpoints/
USE_SQLITE_CHECKPOINT=true

# RAG
CHROMA_PERSIST_DIR=data/chroma
RAG_RETRIEVE_N=20
RAG_TOP_K=5
RAG_RERANK_ENABLED=true
RAG_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Graph limits
MAX_DIFF_FILES=30
MAX_DIFF_LINES=500

# Features
ENABLE_SAST=false
POST_PR_COMMENTS=false
HEURISTIC_ONLY=false

# Notifications (stub logs to data/notification.log if SMTP unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFY_FROM=
NOTIFY_TO=
